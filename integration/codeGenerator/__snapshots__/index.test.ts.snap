exports[`codeGenerator > correct generate file 4`] = `
"import * as DP from "@duplojs/utils/dataParser";

import { TheDate } from "@duplojs/utils/date";

import { userIdDataParser } from "./userIdDataParser";

import { userNameDataParser } from "./userNameDataParser";

import { $userDataParser } from "./types";

export const userDataParser: DP.DataParser<$userDataParser, unknown> = DP.object({
    id: userIdDataParser,
    name: userNameDataParser,
    age: DP.number(),
    friends: DP.optional(DP.array(DP.lazy(() => userDataParser))),
    createdAt: DP.optional(DP.date())
});"
`;

