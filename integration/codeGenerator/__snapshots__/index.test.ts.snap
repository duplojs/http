export type User = {
    id: UserId;
    name: UserName;
    age: number;
    friends?: User[] | undefined;
    createdAt?: (SerializedTheDate | TheDate) | undefined;
};

export type Routes = {
    method: "GET";
    path: "/users";
    responses: {
