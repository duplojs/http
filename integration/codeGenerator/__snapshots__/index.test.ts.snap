} | {
    method: "POST";
    path: "/users";
    body: {
        id: UserId;
        name: UserName;
        age: number;
        friends?: User[] | undefined;
        createdAt?: (SerializedTheDate | TheDate) | undefined;
    };
    responses: {
        code: "422";
        information: "extract-error";
        body?: undefined;
    } | {
        code: "200";
        information: "users.create";
        body: User;
    };
} | {
    method: "DELETE";
